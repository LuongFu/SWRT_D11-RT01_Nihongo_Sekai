@{
    var hideNavbar = ViewData["HideNavbar"] as bool? ?? false;
    var hideFooter = ViewData["HideFooter"] as bool? ?? false;
    var title = ViewData["Title"] as string ?? "Nihongo Sekai";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title</title>

    @* Optional head elements per-page *@
    @RenderSection("Head", required: false)

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" />
    <link rel="icon" type="image/png" href="~/logo/LogoNihongoSekaiPNGBackground.png" />

    @* Allow pages to inject their own CSS *@
    @RenderSection("Styles", required: false)
</head>
<body class="@(ViewData["LockScroll"] as bool? == true ? "home-lock-scroll" : "")">
    <div class="d-flex flex-column min-vh-100">

        @* Render Navbar Partial unless hidden *@
        @if (!hideNavbar)
        {
            @await Html.PartialAsync("_Navbar")
        }

        <main class="flex-grow-1">
            @RenderBody()

            @* Chatbot Iframe *@
            <iframe id="chatbot-iframe"
                    src="https://chat-bot-with-gemini-fe.onrender.com"
                    style="position: fixed;
                           bottom: 0;
                           right: 0;
                           width: 400px;
                           height: 500px;
                           border: none;
                           z-index: 9999;
                           border-radius: 12px;">
            </iframe>
        </main>

        @* Render Footer Partial unless hidden *@
        @if (!hideFooter)
        {
            @await Html.PartialAsync("_Footer")
        }

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* Allow pages to inject their own JS *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
<script src="~/js/script.js"></script>
