@* Views/Shared/_Navbar.cshtml *@
@{
    var hideNavbar = ViewData["HideNavbar"] as bool? ?? false;
}
@if (!hideNavbar)
{
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light navbar-gradient shadow-sm mb-3">
            <div class="container-fluid">
                <button class="navbar-toggler"
                        type="button"
                        data-toggle="collapse"
                        data-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav role-nav align-items-center">
                        @* Admin (unchanged) *@
                        @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link role-link" asp-area="" asp-controller="Admin" asp-action="Index">
                                    <img src="~/logo/LogoNihongoSekaiPNGBackground.png"
                                         width="90"
                                         height="90"
                                         alt="Logo" />
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link role-link" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-people me-1"></i> Home
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link role-link" asp-controller="Account" asp-action="Users">
                                    <i class="bi bi-people me-1"></i> User List
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link role-link" asp-controller="Courses" asp-action="Index">
                                    <i class="bi bi-camera-reels me-1"></i> Courses
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link role-link" asp-controller="Videos" asp-action="Index">
                                    <i class="bi bi-person-square me-1"></i> Videos
                                </a>
                            </li>
                        }
                        @* Partner & Learner/Anonymous share this simplified menu *@
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link role-link" asp-controller="Learners" asp-action="Index">
                                    <img src="~/logo/LogoNihongoSekaiPNGBackground.png"
                                         width="90"
                                         height="90"
                                         alt="Logo" />
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link role-link" asp-controller="Learners" asp-action="Index">
                                    <i class="bi bi-house-door me-1"></i> Home
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link role-link" asp-controller="Courses" asp-action="Index">
                                    <i class="bi bi-book me-1"></i> Courses
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link role-link" asp-controller="Classrooms" asp-action="Index">
                                    <i class="bi bi-easel me-1"></i> Classrooms
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link role-link" asp-controller="Partners" asp-action="Index">
                                    <i class="bi bi-people-fill me-1"></i> Partners
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link role-link" asp-controller="SidePages" asp-action="About">
                                    <i class="bi bi-info-circle me-1"></i> About
                                </a>
                            </li>
                        }
                    </ul>

                    @* Search bar (unchanged) *@
                    <form asp-controller="Courses"
                          asp-action="Filter"
                          method="get"
                          class="search-bar-container">
                        <div class="search-bar">
                            <input type="text"
                                   name="searchString"
                                   class="search-input form-control"
                                   placeholder="Looking for a course?..." />
                            <button type="submit" class="btn btn-link p-0">
                                <i class='bx bx-search'></i>
                            </button>
                        </div>
                    </form>

                    @* Cart summary *@
                    <ul class="navbar-nav">
                        @await Component.InvokeAsync("ShoppingCartSummary")
                    </ul>

                    @* Identity/sign-in *@
                    <partial name="_Identity" />
                </div>
            </div>
        </nav>
    </header>
    <script src="~/js/script.js"></script>
}
