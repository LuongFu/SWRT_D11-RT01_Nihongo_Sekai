                justify-content: center;
                font-weight: 600;
                color: var(--color-gray-600);
              ">
                    Tokyo University
                </div>
                <div class="partner-logo"
                     style="
                width: 120px;
                height: 60px;
                background: var(--color-gray-200);
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 600;
                color: var(--color-gray-600);
              ">
                    JLPT Official
                </div>
                <div class="partner-logo"
                     style="
                width: 120px;
                height: 60px;
                background: var(--color-gray-200);
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 600;
                color: var(--color-gray-600);
              ">
                    Waseda Uni
                </div>
                <div class="partner-logo"
                     style="
                width: 120px;
                height: 60px;
                background: var(--color-gray-200);
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 600;
                color: var(--color-gray-600);
              ">
                    JET Program
                </div>
                <div class="partner-logo"
                     style="
                width: 120px;
                height: 60px;
                background: var(--color-gray-200);
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 600;
                color: var(--color-gray-600);
              ">
                    Japan Foundation
                </div>
            </div>
        </div>
    </section>

        <!-- Partnership Benefits -->
        <section class="benefits-section">
            <div class="container">
                <div class="benefits-content">
                    <div class="benefits-text">
                        <h2 class="section-title">Why Partner with Nihongo Sekai?</h2>
                        <p class="benefits-description">
                            Our partnerships go beyond simple integration. We work closely
