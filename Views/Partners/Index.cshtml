            </div>
        </section>

        <!-- Partnership Process -->
        <section class="process-section">
            <div class="container">
                <h2 class="section-title">Partnership Process</h2>
                <div class="process-timeline">
                    <div class="process-step">
                        <div class="step-number">1</div>
                        <div class="step-content">
                            <h3 class="step-title">Initial Consultation</h3>
                            <p class="step-description">
                                We discuss your organization's needs, goals, and how our
                                platform can support your objectives.
                            </p>
                        </div>
                    </div>
                    <div class="process-step">
                        <div class="step-number">2</div>
                        <div class="step-content">
                            <h3 class="step-title">Proposal Development</h3>
                            <p class="step-description">
                                Our team creates a customized partnership proposal with
                                pricing, implementation timeline, and support details.
                            </p>
                        </div>
                    </div>
                    <div class="process-step">
                        <div class="step-number">3</div>
                        <div class="step-content">
                            <h3 class="step-title">Pilot Program</h3>
                            <p class="step-description">
                                Start with a small-scale pilot to test integration and gather
                                feedback before full implementation.
                            </p>
                        </div>
                    </div>
                    <div class="process-step">
                        <div class="step-number">4</div>
                        <div class="step-content">
                            <h3 class="step-title">Full Implementation</h3>
                            <p class="step-description">
                                Roll out the complete solution with ongoing support, training,
                                and regular check-ins for optimization.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

    <!-- Partnership Form Section -->
    <section class="partnership-form-section">
        <div class="container">
            <div class="section-header">
                <h2>Ready to Partner with Us?</h2>
                <p>
                    Join our community of expert Japanese teachers and share your
                    knowledge with students worldwide
                </p>
            </div>

            <div class="form-container">
                <form id="partnershipForm">
                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label" for="teacherName">Full Name *</label>
                            <input type="text"
                                   id="teacherName"
                                   name="teacherName"
                                   class="form-input"
                                   required />
                        </div>

                        <div class="form-group">
                            <label class="form-label" for="teacherEmail">Email Address *</label>
                            <input type="email"
                                   id="teacherEmail"
                                   name="teacherEmail"
                                   class="form-input"
                                   required />
                        </div>

                        <div class="form-group">
                            <label class="form-label" for="teacherPhone">Phone Number</label>
                            <input type="tel"
                                   id="teacherPhone"
                                   name="teacherPhone"
                                   class="form-input" />
                        </div>

                        <div class="form-group">
                            <label class="form-label" for="teachingExperience">Years of Experience *</label>
                            <select id="teachingExperience"
                                    name="teachingExperience"
                                    class="form-select"
                                    required>
                                <option value="">Select experience</option>
                                <option value="1-2">1-2 years</option>
                                <option value="3-5">3-5 years</option>
                                <option value="6-10">6-10 years</option>
                                <option value="10+">10+ years</option>
                            </select>
                        </div>

                        <div class="form-group full-width">
                            <label class="form-label" for="specializations">Specializations</label>
                            <div style="
                      display: grid;
                      grid-template-columns: repeat(
                        auto-fit,
                        minmax(200px, 1fr)
                      );
                      gap: 1rem;
                      margin-top: 0.5rem;
                    ">
                                <label style="display: flex; align-items: center; gap: 0.5rem">
                                    <input type="checkbox"
                                           name="specializations"
                                           value="conversation" />
                                    <span>Conversation Practice</span>
                                </label>
                                <label style="display: flex; align-items: center; gap: 0.5rem">
                                    <input type="checkbox"
                                           name="specializations"
                                           value="business" />
                                    <span>Business Japanese</span>
                                </label>
                                <label style="display: flex; align-items: center; gap: 0.5rem">
                                    <input type="checkbox"
                                           name="specializations"
                                           value="jlpt" />
                                    <span>JLPT Preparation</span>
                                </label>
                                <label style="display: flex; align-items: center; gap: 0.5rem">
                                    <input type="checkbox"
                                           name="specializations"
                                           value="grammar" />
                                    <span>Grammar</span>
                                </label>
                                <label style="display: flex; align-items: center; gap: 0.5rem">
                                    <input type="checkbox"
                                           name="specializations"
                                           value="culture" />
                                    <span>Cultural Studies</span>
                                </label>
                                <label style="display: flex; align-items: center; gap: 0.5rem">
                                    <input type="checkbox"
                                           name="specializations"
                                           value="pronunciation" />
                                    <span>Pronunciation</span>
                                </label>
                            </div>
                        </div>

                        <div class="form-group full-width">
                            <label class="form-label" for="teachingBackground">Teaching Background & Experience *</label>
                            <textarea id="teachingBackground"
                                      name="teachingBackground"
                                      class="form-textarea"
                                      rows="4"
                                      placeholder="Tell us about your teaching experience, qualifications, and approach..."
                                      required></textarea>
                        </div>

                        <div class="form-group full-width">
                            <label class="form-label" for="certificates">Certificates & Qualifications</label>
                            <input type="file"
                                   id="certificates"
                                   name="certificates"
                                   class="form-input"
                                   accept=".pdf,.doc,.docx,.jpg,.png"
                                   multiple />
                            <small style="
                      color: var(--color-gray-600);
                      font-size: 0.875rem;
                      margin-top: 0.25rem;
                      display: block;
                    ">
                                Upload your teaching certificates, degrees, or JLPT
                                certificates (PDF, DOC, or images)
                            </small>
                        </div>
                    </div>

                    <div style="text-align: center; margin-top: 2rem">
                        <button type="submit" class="btn btn-primary btn-lg">
                            Request Partnership
                        </button>
                    </div>
                </form>
            </div>
        </div>
            <div class="contact-info">
                <div class="contact-method">
                    <h3>Direct Contact</h3>
                    <p><strong>Email:</strong> partnerships@nihongosekai.com</p>
                    <p><strong>Phone:</strong> +1 (555) 123-4569</p>
                    <p><strong>Response Time:</strong> Within 24 hours</p>
                </div>
            </div>
    </section>
</main>

<!-- Chat Modal -->
<div class="chat-modal" id="chatModal">
    <div class="chat-modal-content">
        <div class="chat-header">
            <div class="chat-partner-info">
                <div class="chat-partner-avatar" id="chatPartnerAvatar">
                    <!-- Avatar will be populated by JavaScript -->
                </div>
                <div class="chat-partner-details">
                    <h4 id="chatPartnerName">Partner Name</h4>
                    <p class="chat-partner-status" id="chatPartnerStatus">
                        Available
                    </p>
                </div>
            </div>
            <button class="chat-close-btn" id="chatCloseBtn">×</button>
        </div>

        <div class="chat-messages" id="chatMessages">
            <!-- Messages will be populated by JavaScript -->
        </div>

        <div class="chat-input-area">
            <form class="chat-input-form" id="chatForm">
                <textarea class="chat-input"
                          id="chatInput"
                          placeholder="Type your message..."
                          rows="1"></textarea>
                <button type="submit" class="chat-send-btn">
                    <svg width="16"
                         height="16"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="2">
                        <line x1="22" y1="2" x2="11" y2="13"></line>
                        <polygon points="22,2 15,22 11,13 2,9 22,2"></polygon>
                    </svg>
                </button>
            </form>
        </div>
    </div>
</div>

<!-- Scripts -->
<script src="../js/global.js"></script>
<script src="../js/partners.js"></script>
