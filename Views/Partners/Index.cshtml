                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="benefits-image">
                        <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=500&h=600&fit=crop"
                             alt="Partnership Benefits" />
                    </div>
                </div>
            </div>
        </section>

        <!-- Success Stories -->
        <section class="success-stories-section">
            <div class="container">
                <h2 class="section-title">Partnership Success Stories</h2>
                <div class="stories-grid">
                    <div class="story-card">
                        <div class="story-header">
                            <div class="story-logo">
                                <div class="logo-placeholder small">TU</div>
                            </div>
                            <div class="story-info">
                                <h3 class="story-partner">Tokyo University</h3>
                                <div class="story-type">Educational Partnership</div>
                            </div>
