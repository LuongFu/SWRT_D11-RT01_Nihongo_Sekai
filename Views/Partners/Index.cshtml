                </p>
            </div>
        </div>
    </section> *@

    <!-- Featured Partners Section -->
    <section class="featured-partners">
        <div class="container">
            <div class="section-header">
                <h2>Featured Teaching Partners</h2>
                <p>
                    Meet our top-rated teachers who have helped thousands of students
                    master Japanese
                </p>
            </div>

            <div class="featured-partners-grid" id="featuredPartnersGrid">
                <!-- Featured partners will be populated by JavaScript -->
            </div>

            <div class="view-all-partners">
                <a href="#directory" class="btn btn-primary btn-lg">View All Partners</a>
            </div>
        </div>
    </section>

    <!-- Partners Directory Section -->
    <section class="partners-directory" id="directory">
        <div class="container">
            <div class="section-header">
                <h2>Teacher Directory</h2>
                <p>
                    Browse our complete directory of qualified Japanese teachers and
                    language partners
                </p>
            </div>

            <!-- Directory Filters -->
            <div class="directory-filters">
                <div class="container">
                    <div class="filters-container">
                        <div class="filters-group">
                            <select id="expertiseFilter" class="filter-select">
                                <option value="">All Specializations</option>
                                <option value="Business Japanese Expert">
                                    Business Japanese
                                </option>
                                <option value="Conversation Specialist">
                                    Conversation
                                </option>
                                <option value="JLPT Preparation">JLPT Preparation</option>
                                <option value="Grammar Specialist">Grammar</option>
                                <option value="Cultural Studies">Cultural Studies</option>
                                <option value="Test Preparation">Test Preparation</option>
                                <option value="Travel Japanese">Travel Japanese</option>
                                <option value="Pronunciation">Pronunciation</option>
                            </select>

                            <select id="ratingFilter" class="filter-select">
                                <option value="">All Ratings</option>
                                <option value="4.8">4.8+ Stars</option>
                                <option value="4.5">4.5+ Stars</option>
                                <option value="4.0">4.0+ Stars</option>
                            </select>

                            <select id="availabilityFilter" class="filter-select">
                                <option value="">All Availability</option>
                                <option value="Available">Available Now</option>
                                <option value="Busy">Accepting Wait List</option>
                            </select>
                        </div>

                        <div class="search-container">
                            <svg class="search-icon"
                                 width="16"
                                 height="16"
                                 viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="2">
                                <circle cx="11" cy="11" r="8"></circle>
                                <path d="m21 21-4.35-4.35"></path>
                            </svg>
                            <input type="text"
                                   id="partnerSearch"
                                   class="search-input"
                                   placeholder="Search teachers by name or expertise..." />
                        </div>
                    </div>
                </div>
            </div>

            <div class="partners-grid" id="partnersGrid">
                <!-- Partners directory will be populated by JavaScript -->
            </div>
        </div>
    </section>

    <!-- Trusted Partners Section -->
    <section class="trusted-partners">
        <div class="container">
            <div class="section-header">
                <h2>Our Trusted Partners</h2>
                <p>
                    Recognized institutions and organizations that trust our platform
