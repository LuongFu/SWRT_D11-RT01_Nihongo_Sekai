@using JapaneseLearningPlatform.Data.ViewModels
@model LoginVM

@{
    ViewData["Title"] = "Japanese Partners - Nihongo Sekai";
    Layout = "_Layout";
    ViewData["HideNavbar"] = false;
    ViewData["HideFooter"] = false;
}

@section Head {
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Japanese Partners - Nihongo Sekai</title>
    <meta name="description"
          content="Connect with certified Japanese teachers and language partners. Find the perfect tutor for personalized Japanese lessons and conversation practice." />
}


@section Styles {
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700;800&display=swap"
          rel="stylesheet" />

    <!-- Global CSS -->
    <link rel="stylesheet" href="../css/global.css" />
    <!-- Page-specific CSS -->
    <link rel="stylesheet" href="../css/styles.css" />
    <link rel="stylesheet" href="../css/partners.css" />
    <link rel="stylesheet" href="~/css/footer.css" />
}

<!-- Main Content -->
<main>
    <!-- Hero Section -->
    <section class="partners-hero">
        <div class="container">
            <div class="hero-content">
                <h1 class="hero-title">
                    Partner with Us to
                    <span class="text-gradient">Bridge Cultures</span>
                </h1>
                <p class="hero-description">
                    Join our network of educational institutions, businesses, and
                    cultural organizations to expand access to Japanese language
                    learning worldwide. Together, we can build bridges between
                    cultures and create meaningful connections.
                </p>
                <div class="hero-actions">
                    <button class="btn btn-primary" onclick="showPartnershipForm()">
                        Become a Partner
                    </button>
                    <a href="#partnership-types" class="btn btn-outline">Explore Partnerships</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Partnership Types -->
    <section class="partnership-types-section" id="partnership-types">
        <div class="container">
            <h2 class="section-title">Partnership Opportunities</h2>
            <div class="partnership-grid">
                <div class="partnership-card">
                    <div class="partnership-icon">🏫</div>
                    <h3 class="partnership-title">Educational Institutions</h3>
                    <p class="partnership-description">
                        Partner with universities, schools, and educational
                        organizations to integrate Japanese language learning into
                        curricula and offer student discounts.
                    </p>
                    <div class="partnership-benefits">
                        <h4>Benefits:</h4>
                        <ul>
                            <li>Bulk licensing discounts</li>
                            <li>Custom curriculum development</li>
                            <li>Teacher training programs</li>
                            <li>Student progress tracking</li>
                        </ul>
                    </div>
                    <button class="btn btn-outline"
                            onclick="inquirePartnership('education')">
                        Learn More
                    </button>
                </div>

                <div class="partnership-card">
                    <div class="partnership-icon">🏢</div>
                    <h3 class="partnership-title">Corporate Training</h3>
                    <p class="partnership-description">
                        Provide Japanese language training for businesses working with
                        Japanese companies or expanding into the Japanese market.
                    </p>
                    <div class="partnership-benefits">
                        <h4>Benefits:</h4>
                        <ul>
                            <li>Business-focused curriculum</li>
                            <li>Flexible scheduling</li>
                            <li>Corporate reporting tools</li>
                            <li>Cultural training modules</li>
                        </ul>
                    </div>
                    <button class="btn btn-outline"
                            onclick="inquirePartnership('corporate')">
                        Learn More
                    </button>
                </div>

                <div class="partnership-card">
                    <div class="partnership-icon">🌍</div>
                    <h3 class="partnership-title">Cultural Organizations</h3>
                    <p class="partnership-description">
                        Collaborate with cultural centers, museums, and Japan-related
                        organizations to promote Japanese culture through language
                        learning.
                    </p>
                    <div class="partnership-benefits">
                        <h4>Benefits:</h4>
                        <ul>
                            <li>Cultural content integration</li>
                            <li>Event partnerships</li>
                            <li>Cross-promotion opportunities</li>
                            <li>Community outreach programs</li>
                        </ul>
                    </div>
                    <button class="btn btn-outline"
                            onclick="inquirePartnership('cultural')">
                        Learn More
                    </button>
                </div>

                <div class="partnership-card">
                    <div class="partnership-icon">💻</div>
                    <h3 class="partnership-title">Technology Partners</h3>
                    <p class="partnership-description">
                        Integrate with learning management systems, educational
                        platforms, and technology solutions to enhance the learning
                        experience.
                    </p>
                    <div class="partnership-benefits">
                        <h4>Benefits:</h4>
                        <ul>
                            <li>API integration support</li>
                            <li>Technical documentation</li>
                            <li>Co-marketing opportunities</li>
                            <li>Revenue sharing programs</li>
                        </ul>
                    </div>
                    <button class="btn btn-outline"
                            onclick="inquirePartnership('technology')">
                        Learn More
                    </button>
                </div>
            </div>
        </div>
    </section>
    @* <!-- Enhanced Hero Section -->
    <section class="enhanced-hero">
        <div class="container">
            <div class="enhanced-hero-content">
                <h1 class="enhanced-hero-title">
                    Connect with Expert Japanese Teachers
